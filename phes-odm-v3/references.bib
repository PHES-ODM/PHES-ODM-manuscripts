	abstract = {To inform the development of global wastewater monitoring systems, we surveyed programmes in 43 countries. Most programmes monitored predominantly urban populations. In high-income countries (HICs), composite sampling at centralised treatment plants was most common, whereas grab sampling from surface waters, open drains, and pit latrines was more typical in low-income and middle-income countries (LMICs). Almost all programmes analysed samples in-country, with an average processing time of 2·3 days in HICs and 4·5 days in LMICs. Whereas 59\% of HICs regularly monitored wastewater for SARS-CoV-2 variants, only 13\% of LMICs did so. Most programmes share their wastewater data internally, with partnering organisations, but not publicly. Our findings show the richness of the existing wastewater monitoring ecosystem. With additional leadership, funding, and implementation frameworks, thousands of individual wastewater initiatives can coalesce into an integrated, sustainable network for disease surveillance—one that minimises the risk of overlooking future global health threats.},
	language = {en},
	number = {6},
	urldate = {2023-05-19},
	journal = {The Lancet Global Health},
	author = {Keshaviah, Aparna and Diamond, Megan B and Wade, Matthew J and Scarpino, Samuel V and Ahmed, Warish and Amman, Fabian and Aruna, Olusola and Badilla-Aguilar, Andrei and Bar-Or, Itay and Bergthaler, Andreas and Bines, Julie E and Bivins, Aaron W and Boehm, Alexandria B and Brault, Jean-Martin and Burnet, Jean-Baptiste and Chapman, Joanne R and Chaudhuri, Angela and de Roda Husman, Ana Maria and Delatolla, Robert and Dennehy, John J and Diamond, Megan Beth and Donato, Celeste and Duizer, Erwin and Egwuenu, Abiodun and Erster, Oran and Fatta-Kassinos, Despo and Gaggero, Aldo and Gilpin, Deirdre F and Gilpin, Brent J and Graber, Tyson E and Green, Christopher A and Handley, Amanda and Hewitt, Joanne and Holm, Rochelle H and Insam, Heribert and Johnson, Marc C and Johnson, Rabia and Jones, Davey L and Julian, Timothy R and Jyothi, Asha and Keshaviah, Aparna and Kohn, Tamar and Kuhn, Katrin G and La Rosa, Giuseppina and Lesenfants, Marie and Manuel, Douglas G and D'Aoust, Patrick M and Markt, Rudolf and McGrath, John W and Medema, Gertjan and Moe, Christine L and Murni, Indah Kartika and Naser, Humood and Naughton, Colleen C and Ogorzaly, Leslie and Oktaria, Vicka and Ort, Christoph and Karaolia, Popi and Patel, Ekta H and Paterson, Steve and Rahman, Mahbubur and Rivera-Navarro, Pablo and Robinson, Alex and Santa-Maria, Monica C and Scarpino, Samuel V and Schmitt, Heike and Smith, Theodore and Stadler, Lauren B and Stassijns, Jorgen and Stenico, Alberta and Street, Renee A and Suffredini, Elisabetta and Susswein, Zachary and Trujillo, Monica and Wade, Matthew J and Wolfe, Marlene K and Yakubu, Habib and Zanoli Sato, Maria Ines},
	month = jun,
	year = {2023},
